        if ( m_nextchar == '=' ) {
          PeekNextChar();
          return new Token( G.BE, "<=", ms_lineNumber, ms_columnNumber  );
        } // if
        else if ( m_nextchar == '>' ) {
          PeekNextChar();
          return new Token( G.BE, "<>", ms_lineNumber, ms_columnNumber  );  
        } // else if
        else
          return new Token( G.BE, "<", ms_lineNumber, ms_columnNumber  );
      } // else if
      else if ( first == '>' ) { // >= 或 > 
        if ( m_nextchar == '=' ) { 
          PeekNextChar();
          return new Token( G.BE, ">=", ms_lineNumber, ms_columnNumber  );
