              donothing = 0;  
            else if ( mTL.get( i ).mtype == G.RSP && check_dwie == true   ) {
              if ( get_dwie == G.WHILE && checkdowhile.indexOf( spacenum ) != -1 ) { 
                checkdowhile.remove( checkdowhile.indexOf( spacenum ) );  // 先檢查特例 do while(的while)
                System.out.print( " " );
              } // if
              
              else if ( tpeek != G.LBP ) { // 沒有大刮是一行的
                check_noLBP = true;
                spacenum = spacenum + 2;
                linestart = true;
                System.out.print( "\n" );
              } // if
              
              else
                System.out.print( " " ); // 平常例子
            } // else if
            

            
            else    
