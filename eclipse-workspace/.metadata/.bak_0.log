    } // else if
    else if ( first == '*' ) // *
      return new Token( G.STAR, "*", ms_lineNumber, ms_columnNumber  );
    else if ( first == '(' )
      return new Token( G.LP, "(", ms_lineNumber, ms_columnNumber  );
    else if ( first == ')'  ) 
      return new Token( G.RP, ")", ms_lineNumber, ms_columnNumber  );
    else if ( first == ';' )
      return new Token( G.SC, ";", ms_lineNumber, ms_columnNumber  );
