class SCANNER {
  public LinkedHashMap<String,String> mLHM = new LinkedHashMap<String,String>();
  public ArrayList<Token> mTokenlist = new ArrayList<Token>(); // 放每個token 用完刪除remove_all
  public Token mnow_token;
  public int m_tokenNum = 0 ; // token
  public int ms_lineNumber = 1;
  public int ms_columnNumber = 1;
  public char m_nextchar = '\0';
  public Token FetchToken() throws Throwable {
    char first = '\0';
    String str = new String(); 
    if ( IsSpace( m_nextchar ) ) // 不是whitespace
      m_nextchar = GetNextNonWhiteSpaceChar(); // 拿下一個非white的token
    first = m_nextchar;
    PeekNextChar();
    int check = 0;
    str = str + first;  
    if ( first == '\0' ) // EOF了
      return new Token( G.EOF, "", ms_lineNumber, ms_columnNumber  );   
    else if ( IsLetter( first ) ) { // 字母開頭
      while ( IsLetter( this.m_nextchar ) || IsNum( this.m_nextchar ) || m_nextchar == '_'   ) {
        first = m_nextchar; // 字母的話可以是字母數字下底線----是這三者的話
        str = str + first;
        PeekNextChar();   
        if ( str.equals( "quit" ) && IsSpace( m_nextchar ) ) // quit的狀況 很稀少
          return new Token( G.QUIT, str, ms_lineNumber, ms_columnNumber   );
      } // while
      
      return new Token( G.IDENT, str, ms_lineNumber, ms_columnNumber  ); 
    } // else if
    else if ( IsNum( first ) ) { // 有可能是數字or小數
      if ( m_nextchar == '.' )
        check = check + 1;
      while ( ( IsNum( this.m_nextchar ) || this.m_nextchar == '.' ) && check < 2 ) { 
        first = m_nextchar; // 數字的話可以是.或是數字且只能有一個小數點----是這二者的話
        str = str + first;
        PeekNextChar();   
        if ( this.m_nextchar == '.' ) // 有一個點點 不能超過兩個
          check = check + 1; 
      } // while
      
      return new Token( G.NUM, str, ms_lineNumber, ms_columnNumber  );
    } // else if 
    else if ( first == '.' ) { // ..後面只能是數字
      if ( ! IsNum( this.m_nextchar ) ) // 下一個一定要是數字才對
        return new Token( G.UNKNOWN, str, ms_lineNumber, ms_columnNumber  );
      while (  IsNum( this.m_nextchar ) ) { // 數字的話可以是.或是數字且只能有一個小數點
        first = m_nextchar; // 是這三者的話
        str = str + first;
        PeekNextChar();        
      } // while
      
      return new Token( G.NUM, str, ms_lineNumber, ms_columnNumber  );
    } // else if
    else if ( IsSign( first ) ) { // 符號
      str = str + first;
      return new Token( G.SIGN, str, ms_lineNumber, ms_columnNumber  );
    } // else if
  
    else if ( first == '/' ) {  // 單個通常是註解
      if ( this.m_nextchar == '/' ) {
        while ( !G.sin.AtEOLN()  ) {
          PeekNextChar();
          if( m_nextchar == '\0' ) // 註解到結束eof
            return new Token( G.EOF, "", ms_lineNumber, ms_columnNumber  );
        } // while
        
        m_nextchar = GetNextNonWhiteSpaceChar();
        return FetchToken(); // 註解就找下個去
      } // if
      else 
        return new Token( G.DIV, "/", ms_lineNumber, ms_columnNumber  );
    } // else if
    else if ( first == '*' ) // *
      return new Token( G.STAR, "*", ms_lineNumber, ms_columnNumber  );
    else if ( first == '(' )
      return new Token( G.LP, "(", ms_lineNumber, ms_columnNumber  );
    else if ( first == ')'  ) 
      return new Token( G.RP, ")", ms_lineNumber, ms_columnNumber  );
    else if ( first == ';' )
      return new Token( G.SC, ";", ms_lineNumber, ms_columnNumber  );
    else if ( IsBo( first ) ) {
      if ( first == ':' ) {
        if ( m_nextchar == '=' ) { // 是定義喔
          PeekNextChar();
          return new Token( G.DS, ":=", ms_lineNumber, ms_columnNumber  );
        } // if
        else
          return new Token( G.UNKNOWN, ":", ms_lineNumber, ms_columnNumber  );
      } // if 
      else if ( first == '<' ) { // <= 或 <> 或<
        if ( m_nextchar == '=' ) {
          PeekNextChar();
          return new Token( G.BE, "<=", ms_lineNumber, ms_columnNumber  );
        } // if
        else if ( m_nextchar == '>' ) {
          PeekNextChar();
          return new Token( G.BE, "<>", ms_lineNumber, ms_columnNumber  );  
        } // else if
        else
          return new Token( G.BE, "<", ms_lineNumber, ms_columnNumber  );
      } // else if
      else if ( first == '>' ) { // >= 或 > 
        if ( m_nextchar == '=' ) { 
          PeekNextChar();
          return new Token( G.BE, ">=", ms_lineNumber, ms_columnNumber  );
        } // if
        else 
          return new Token( G.BE, ">", ms_lineNumber, ms_columnNumber  );
      } // else if
      else // =
        return new Token( G.BE, "=", ms_lineNumber, ms_columnNumber  );  
    } // else if 
    else   
      return new Token( G.UNKNOWN, str, ms_lineNumber, ms_columnNumber  );
  } // FetchToken()
  
  public void PeekNextChar() throws Throwable {
    CharObj cx = new CharObj('\0');
    if ( G.sin.ReadChar( cx ) == false   ) {  // EOF
      m_nextchar = '\0';
      return;
    } // if
    m_nextchar = cx.val;
    if ( m_nextchar == '\n' ) {
      ms_lineNumber++;
      ms_columnNumber = 1;
    } // if
    else
      ms_columnNumber++;
  } // PeekNextChar()
  
  public char GetNextNonWhiteSpaceChar() throws Throwable {
    CharObj cx = new CharObj('\0');
    while ( cx.val == '\0' || cx.val == '\t' || cx.val == ' ' ||  cx.val == '\n' ) {
      if ( G.sin.ReadChar( cx ) == false   )  // EOF
        return '\0';
      if ( cx.val == '\n' ) {
        ms_lineNumber++;
        ms_columnNumber = 1;
      } // if
      else
        ms_columnNumber++;
    } // while       
    return cx.val;
  } // GetNextNonWhiteSpaceChar()
  
  public boolean IsLetter( char c ) throws Throwable {
    if ( ( c >= 'a' && c <= 'z' ) || (  c >= 'A' &&  c <= 'Z' )  )
      return true;
    else
      return false;
  } // IsLetter()
  
  public boolean IsNum( char c ) throws Throwable {
    if ( c >= '0' && c <= '9' )
      return true;
    else
      return false;
  } // IsNum()  
  
  public boolean IsSign( char c ) throws Throwable {
    if ( c == '+' || c == '-' )
      return true;
    else 
      return false;
  } // IsSign()
  
  public boolean IsSpace( char c ) throws Throwable {
    if ( c == '\t' || c == ' ' || c == '\n'  )
      return true;
    else
      return false;
  } // IsSpace()
  
  public boolean IsBo( char c ) throws Throwable {
    if ( c == '>' || c == '<' ||  c == '=' || c == ':' )
      return true;
    else
      return false;
  } // IsBo()
  
  public ArrayList<Token> GetTokenList() throws Throwable {
    return mTokenlist;
  } // GetTokenList()
   
  public void EncounterError() throws Throwable {
    while ( !G.sin.AtEOLN()  ) {
      PeekNextChar();
      if ( m_nextchar == '\0' ) // eof
        return;
    } // while
  } // EncounterError()
} // class SCANNER

class PARSER {
  public ArrayList<Token> mTokenList = null ;
  public SCANNER sc = null;
  public int mTCt; // 主要的計數器
  public int m_nowCommand; // 現在在command的第幾個
  public boolean mError1 = false; // 字元錯誤
  public boolean mError2 = false; // 語法錯誤
  public boolean mError3 = false; // 未定義錯誤
  public boolean mExecute = false; // 讀到分號或是quit的處理
  public int[] mDyerror = null; // 動態error陣列(用來看command有沒有錯，語法分析用)
  public PARSER(SCANNER sc) {
    mTokenList = new ArrayList<Token>();
    this.sc = sc;
    mTCt = 0; // token計數器
    m_nowCommand = 0;
    mDyerror = new int[] { 0, 0, 0 };
  } // PARSER()
  
  public void FetchToken() throws Throwable {
    if ( mTokenList.size() == 0 ) {
      mTokenList.add( sc.FetchToken() );    
    } // if
    
    else {
      mTokenList.add( sc.FetchToken() ) ;
    } // else
    
    for ( int i = 0 ; i < 3 ; i++ ) {
      mDyerror[i] = 0;
    } // for
  } // FetchToken()
  
  
  public void ParserIt()  throws Throwable {
    FetchToken();
    GoCommand();
    ErrorDetectAndHandle();  
  } // ParserIt()
  
  public void GoFactor() throws Throwable {
    if ( mTCt >= mTokenList.size() )
      return;
    if ( mTokenList.get( mTCt ).mtype == G.SIGN ) {
      mTCt++;
      if ( mTCt < mTokenList.size()   ) {
        if ( mTokenList.get( mTCt ).mtype != G.NUM ) // 是數字就對不是就是error
          mDyerror[m_nowCommand] = 1;
        mTCt++;
      } // if 
      else // 下一回合在看看
        return;
    } // if
    
    else if ( mTokenList.get( mTCt ).mtype == G.NUM ) {
      mTCt++;
      return;
    } // else if
    
    else if ( mTokenList.get( mTCt ).mtype == G.IDENT ) {
      mTCt++;
      if ( G.CheckIDInTable( mTokenList.get( mTCt-1 ).mvalue ) == false ) //不再表中代表未定義錯誤
        mError3 = true;
      return;
    } // else if
      
    else if ( mTokenList.get( mTCt ).mtype == G.LP ) {
      mTCt++;
      if ( mTCt >= mTokenList.size() )
        return;
      GoArithExp( );
      if ( mTCt >= mTokenList.size() )
        return;
      if ( mTokenList.get( mTCt ).mtype != G.RP ) // 是數字就對不是就是error
        mDyerror[m_nowCommand] = 1;
      mTCt++;
    } // else if
    else {
      mDyerror[m_nowCommand] = 1;
      mTCt++;
    } // else
  } // GoFactor()
  
  public void GoTerm() throws Throwable {
    GoFactor();
    if ( mTCt >= mTokenList.size() )
      return;
    while ( mTokenList.get( mTCt ).mtype == G.STAR || mTokenList.get( mTCt ).mtype == G.DIV ) {
      mTCt++;
      if ( mTCt >= mTokenList.size() ) 
        return;
      GoFactor();
      if ( mTCt >= mTokenList.size() ) 
        return;
    } // while

  } // GoTerm()
 
  
  public void GoArithExp() throws Throwable {
    GoTerm();
    if ( mTCt >= mTokenList.size() )
      return;
    while ( mTokenList.get( mTCt ).mtype == G.SIGN ) {
      mTCt++;
      if ( mTCt >= mTokenList.size() ) 
        return;
      GoTerm();
      if ( mTCt >= mTokenList.size() ) 
        return;
    } // while
  } // GoArithExp()
  
  
  public void GoBooleanOperator() throws Throwable {
    if ( mTCt >= mTokenList.size() )
      return;
    if ( mTokenList.get( mTCt ).mtype == G.BE ) {
      mTCt++;
    } // if
    else
      mDyerror[m_nowCommand] = 1;  
  } // GoBooleanOperator()
  
  public void GoIDlessArithExpOrBexp() throws Throwable {
    if ( mTCt >= mTokenList.size() )
      return;
    while ( mTokenList.get( mTCt ).mtype == G.STAR || mTokenList.get( mTCt ).mtype == G.DIV || 
            mTokenList.get( mTCt ).mtype == G.SIGN ) {
      mTCt++;
      if ( mTCt >= mTokenList.size() ) 
        return;
      if ( mTokenList.get( mTCt-1 ).mtype == G.STAR || mTokenList.get( mTCt-1 ).mtype == G.DIV )
        GoFactor();
      else if ( mTokenList.get( mTCt-1 ).mtype == G.SIGN )
        GoTerm();  
      if ( mTCt >= mTokenList.size() ) 
        return;
    } // while
    
    if ( mTokenList.get( mTCt ).mtype == G.BE ) {
      GoBooleanOperator();
      if ( mTCt >= mTokenList.size() ) 
        return;
      GoArithExp();
      if ( mTCt >= mTokenList.size() ) 
        return;
    } // if
    
  } // GoIDlessArithExpOrBexp()

  
  public void GoNOT_ID_StartArithExpOrBexp() throws Throwable {
    if ( mTCt >= mTokenList.size() )
      return;
    GoNOT_ID_StartArithExp();
    if ( mTCt >= mTokenList.size() )
      return;
    if ( mTokenList.get( mTCt ).mtype == G.BE ) {
      GoBooleanOperator();
      if ( mTCt >= mTokenList.size() ) 
        return;
      GoArithExp();
      if ( mTCt >= mTokenList.size() ) 
        return;
    } // if  
  } // GoNOT_ID_StartArithExpOrBexp()
  


  public void GoNOT_ID_StartArithExp() throws Throwable {
    if ( mTCt >= mTokenList.size() )
      return;
    GoNOT_ID_StartTerm();
    if ( mTCt >= mTokenList.size() )
      return;
    while (  mTokenList.get( mTCt ).mtype == G.SIGN  ) { // +或-
      mTCt++;
      if ( mTCt >= mTokenList.size() ) 
        return;
      GoTerm();
      if ( mTCt >= mTokenList.size() ) 
        return;
    } // while
  } // GoNOT_ID_StartTerm()
  
  
  public void GoNOT_ID_StartTerm() throws Throwable {
    if ( mTCt >= mTokenList.size() )
      return;
    GoNOT_ID_StartFactor();
    if ( mTCt >= mTokenList.size() )
      return;
    while (  mTokenList.get( mTCt ).mtype == G.STAR || mTokenList.get( mTCt ).mtype == G.DIV   ) { // +或-
      mTCt++;
      if ( mTCt >= mTokenList.size() ) 
        return;
      GoFactor();
      if ( mTCt >= mTokenList.size() ) 
        return;
    } // while
  } // GoNOT_ID_StartTerm()
 
  
  
  public void GoNOT_ID_StartFactor() throws Throwable {
    if ( mTCt >= mTokenList.size() )
      return;
    if ( mTokenList.get( mTCt ).mtype == G.SIGN ) {
      mTCt++;
      if ( mTCt < mTokenList.size()   ) {
        if ( mTokenList.get( mTCt ).mtype != G.NUM ) // 是數字就對不是就是error
          mDyerror[m_nowCommand] = 1;
        mTCt++;
      } // if 
      else // 下一回合在看看
        return;
    } // if
    
    else if ( mTokenList.get( mTCt ).mtype == G.NUM ) {
      mTCt++;
      return;
    } // else if
      
    else if ( mTokenList.get( mTCt ).mtype == G.LP ) {
      mTCt++;
      if ( mTCt >= mTokenList.size() )
        return;
      GoArithExp( );
      if ( mTCt >= mTokenList.size() )
        return;
      if ( mTokenList.get( mTCt ).mtype != G.RP ) // )主要是處理錯誤才對 對的話不用看
        mDyerror[m_nowCommand] = 1;
      mTCt++;
    } // else if
    else {
      mDyerror[m_nowCommand] = 1;
      mTCt++;
    } // else
  } // GoNOT_ID_StartFactor()
  
  public void GoCommand() throws Throwable {
    
    if ( mTokenList.get( mTCt ).mtype == G.IDENT ) {
      mTCt++;
      if ( mTCt >= mTokenList.size() )
        return;
      if ( mTokenList.get( mTCt ).mtype == G.DS ) { // :=
        m_nowCommand = 0;
        mTCt++;
        if ( mTCt >= mTokenList.size() )
          return;
        GoArithExp();    
      } // if
      
      else { // go IDlessArithExpOrBexp
        m_nowCommand = 1;
        if ( G.CheckIDInTable( mTokenList.get( mTCt-1 ).mvalue ) == false ) //不再表中代表未定義錯誤
          mError3 = true;
        GoIDlessArithExpOrBexp();
      } // else
      
      if ( mTCt >= mTokenList.size() )
        return;
      if ( mTokenList.get( mTCt ).mtype == G.SC ) // 分號
        mExecute = true; 
      else 
        mDyerror[m_nowCommand] = 1; // 不是的話語法錯誤  
    } // if
    else if( mTokenList.get( mTCt ).mtype == G.QUIT ) {
      mExecute = true;
      return;
    } // 
    else { // GoNotIDlessArithExpOrBexp
      m_nowCommand = 2;
      GoNOT_ID_StartArithExpOrBexp();
      if ( mTCt >= mTokenList.size() )
        return;
      if ( mTokenList.get( mTCt ).mtype == G.SC ) // 分號
        mExecute = true; 
      else 
        mDyerror[m_nowCommand] = 1; // 不是的話語法錯誤  
    } // else
     
  } // GoCommand()
  
  
  public void ClearIt() throws Throwable {
    mTCt = 0;
    mTokenList.clear();  
    mError1 = false; // 字元錯誤
    mError2 = false; // 語法錯誤
    mError3 = false; // 未定義錯誤
    mExecute = false; // 讀到分號或是quit的處理
    m_nowCommand = 0;
    for ( int i = 0 ; i < 3 ; i++ ) {
      mDyerror[i] = 0;
    } // for
    
  } // ClearIt()
  
  
  public void ErrorDetectAndHandle() throws Throwable {
    if ( mTokenList.size() <= 0) // 應該是不會有這種狀況
      return;
    Token t = mTokenList.get( mTokenList.size() - 1 ); //拿最後一項token = 最新讀的
    if ( t.mtype == G.UNKNOWN ) // 順便檢查Unrecognized
      mError1 = true;
    for ( int i = 0 ; i < 3 ; i++ ) {
      if ( mDyerror[i] == 1 )
       mError2 = true; 
    } // for
    
    if ( mError1 || mError2 || mError3 ) {
      G.ErrorPrint( mError1, mError2, mError3, t  ) ;
      sc.EncounterError();  
      this.ClearIt();
    } // if
  } // ErrorDetectAndHandle()
  
  public boolean GetExecuteState() {
    return mExecute;  
  } // GetExecute()
  
  public ArrayList<Token> GetTable(){
    return mTokenList;  
  } // GetTable()
} // class PARSER

class Evalutor {
  public ArrayList<Token> mExpressionTable = null ;
  public ArrayList<Token> mleft = null ;
  public ArrayList<Token> mleftPostfix = null ;
  public ArrayList<Token> mright = null ;
  public ArrayList<Token> mrightPostfix = null ;    
  public boolean mHas_middle = false;
  public String middle; 
  public Evalutor() {
    mHas_middle = false;
    mleft =  new ArrayList<Token>();
    mright =  new ArrayList<Token>();
    mExpressionTable = new ArrayList<Token>();
    mleftPostfix = new ArrayList<Token>() ;
    mrightPostfix = new ArrayList<Token>();
  }  // Evalutor()
  
  public void Evalute() throws Throwable {  //  id的判斷 ; 解後序==計算結果
    DelimterIt();
    InfixToPostfix();
    boolean isDoubleleft = false;
    boolean isDoubleright = false;
    boolean divzeroerror = false;
    double resultLeft = 0;
    double resultRight = 0;
    double tolerance =  0.0001;
    if ( G.s_quit == 1 )
      return;
    if ( mHas_middle == true ) { // 沒右邊
      if ( middle.equals( ":=" ) ) { // 這代表著左式一定是ID 計算右式即可
        resultRight = CalPostfix( mrightPostfix, isDoubleright, divzeroerror );
        if ( divzeroerror == true ) {
          G.CYPrint("Error\n");  
          return;
        } // if
        
        Identifier ide = new Identifier();
        if ( isDoubleright == true )  // 右邊是有小數是double
          ide.mcheck = "DOUBLE";   
        else
          ide.mcheck = "INT";
        G.CYPrint( resultRight + "\n" ); 
        ide.mtype = G.IDENT;
        ide.mvalue = mleft.get( 0 ).mvalue ; //也就是ident
        ide.mnumvalue = resultRight;
        G.UpdateIDInTable( ide );  
      } // if
      
      else { // 要做布林運算
        resultLeft = CalPostfix( mleftPostfix, isDoubleleft, divzeroerror );
        resultRight = CalPostfix( mrightPostfix, isDoubleright, divzeroerror );
        if ( divzeroerror == true ) {
          G.CYPrint("Error\n");  
          return;
        } // if  
        
        
        if ( middle.equals( "=" ) ) {  // = 或 >= 或 > 或 <= 或 <> 或<
         ( resultLeft > resultRight );       
        } // if
        
        else if ( ) {
          
        } // else if
        
        else if ( ) {
          
        } // else if
        
        else if ( ) {
          
        } // else if
      } // else
      
      
    } // if
    
    else
      middle = "";

    
    
  } // Evalute() 
  
  public void DelimterIt() throws Throwable { // 分割式子
    int i = 0, go_right = 0;
    Token t;
    if ( mExpressionTable.get(0).mtype == G.QUIT ) {
      G.s_quit = 1;
      return;
    } // if
    
    mExpressionTable.remove( mExpressionTable.size() - 1 ); // 去除分號 
    for ( i = 0 ; i < mExpressionTable.size() ; i++ ) { // 把式子分成 兩段 <左邊> <布林符號> <右邊>
      t = mExpressionTable.get( i );  
      if ( t.mtype == G.DS || t.mtype == G.BE ) { // 布林符號
        middle = t.mvalue;
        go_right = 1;
        mHas_middle = true; 
      } // if
        
      else {
        if ( go_right == 0 ) // 左式
          mleft.add(t);
        else // 右式
          mright.add(t);
      } // else  
    } // for
    
    if ( mleft.size() == 2 ) { // 左邊
      if ( mleft.get( 0 ).mvalue.equals( "+" ) )   // 語法正確下可以是[sign] Num
        mleft.remove( 0 );                         // 把其整合成一個 ( 正的不用更改前者)
      else if (  mleft.get( 0 ).mvalue.equals( "-" ) ) {
        mleft.remove( 0 );
        t = mleft.get(0);        // *****之後有錯的話，先轉數字在inverse
        t.mvalue = "-" + t.mvalue ; //幫數字前面補- ，使其變成負號，數字
        mleft.set(0, t);
      } // else if
    } // if
    
    else if ( mleft.size() > 2 ) {
      for ( i = mleft.size()-1 ; i >= 2 ; i--) { // 反向查看
        if ( mleft.get( i ).mtype == G.NUM ) {
          if (  mleft.get( i - 1 ).mvalue.equals( "+" ) ) {
            if (  mleft.get( i - 2 ).mtype != G.NUM && mleft.get( i - 2 ).mtype != G.IDENT )  // 可整合的14
              mleft.remove( i - 1 );
          } // if
          
          else if (  mleft.get( i - 1 ).mvalue.equals( "-" )  ) {
            if (  mleft.get( i - 2 ).mtype != G.NUM && mleft.get( i - 2 ).mtype != G.IDENT ) {  // 可整合的14
              mleft.remove( i - 1 ); 
              t = mleft.get(0);        // *****之後有錯的話，先轉數字在inverse
              t.mvalue = "-" + t.mvalue ; //幫數字前面補- ，使其變成負號，數字
              mleft.set(0, t);
            } // if
          } // else if
        } // if
      } // for  
    } // if
    
    if ( mright.size() > 0 ) { // 這是要把+3,-3這種數字跟符號整合在一起 
      if ( mright.size() == 2 ) { // 必定是這種狀況，不然一定文法錯誤
        if ( mright.get( 0 ).mvalue.equals( "+" ) )   // 語法正確下可以是[sign] Num
          mright.remove( 0 );                         // 把其整合成一個 ( 正的不用更改前者)
        else if (  mright.get( 0 ).mvalue.equals( "-" ) ) {
          mright.remove( 0 );
          t = mright.get(0);        // *****之後有錯的話，先轉數字在inverse
          t.mvalue = "-" + t.mvalue ; //幫數字前面補- ，使其變成負號，數字
          mright.set(0, t);
        } // else if
      } // if
      
      else if ( mright.size() > 2 ) {
        for ( i = mright.size()-1 ; i >= 2 ; i--) { // 反向查看
          if ( mright.get( i ).mtype == G.NUM ) {
            if (  mright.get( i - 1 ).mvalue.equals( "+" ) ) {
              if (  mright.get( i - 2 ).mtype != G.NUM && mright.get( i - 2 ).mtype != G.IDENT)  // 可整合的14
                mright.remove( i - 1 );
            } // if
            
            else if (  mright.get( i - 1 ).mvalue.equals( "-" )  ) {
              if (  mright.get( i - 2 ).mtype != G.NUM && mright.get( i - 2 ).mtype != G.IDENT) {  // 可整合的14
                mright.remove( i - 1 ); 
                t = mright.get(0);        // *****之後有錯的話，先轉數字在inverse
                t.mvalue = "-" + t.mvalue ; //幫數字前面補- ，使其變成負號，數字
                mright.set(0, t);
              } // if
            } // else if
          } // if
        } // for
      } // else if
    } // if
    
  } // DelimterIt() 
  
  
  public void InfixToPostfix() throws Throwable {
    Stack<Token> st = new Stack<Token>();
    Token t;
    int i = 0;
    for ( i = 0 ; i < mleft.size() ; i++ ) {
      t =  mleft.get( i );
      if ( t.mtype == G.NUM ||  t.mtype == G.IDENT ) // 數字
        mleftPostfix.add( t );
      else if ( t.mtype == G.LP ) // (
        st.push( t );
      else if ( t.mtype == G.RP ) { // )
        while ( !st.empty() && st.peek().mtype != G.LP ) { // 右括號就把東溪放出
          mleftPostfix.add( st.pop() );  
        } // while
          
        if ( !st.empty() ) //放出右括號
          st.pop();
      } // else if
      
      else if ( t.mtype == G.SIGN || t.mtype == G.DIV || t.mtype == G.STAR ) { // 運算子
        while ( !st.empty() && Priority( t.mvalue ) <= Priority( st.peek().mvalue ) ) {
         mleftPostfix.add( st.pop() );
        } // while
        
        st.push( t );
      } // else if
    } // for
    
    while ( !st.empty() ) {
      mleftPostfix.add( st.pop() );
     } // while
    
    if ( mHas_middle == true ) {
      for ( i = 0 ; i < mright.size() ; i++ ) {
        t =  mright.get( i );
        if ( t.mtype == G.NUM ||  t.mtype == G.IDENT ) // 數字
          mrightPostfix.add( t );
        else if ( t.mtype == G.LP ) // (
          st.push( t );
        else if ( t.mtype == G.RP ) { // )
          while ( !st.empty() && st.peek().mtype != G.LP ) { // 右括號就把東溪放出
            mrightPostfix.add( st.pop() );  
          } // while
            
          if ( !st.empty() ) //放出右括號
            st.pop();
        } // else if
        
        else if ( t.mtype == G.SIGN || t.mtype == G.DIV || t.mtype == G.STAR ) { // 運算子
          while ( !st.empty() && Priority( t.mvalue ) <= Priority( st.peek().mvalue ) ) {
            mrightPostfix.add( st.pop() );
          } // while
          
          st.push( t );
        } // else if
      } // for  
      
      while ( !st.empty() ) {
        mrightPostfix.add( st.pop() );
       } // while
    } // if 
    
  } // InfixToPostfix()
  
  public double CalPostfix( ArrayList<Token> al, boolean IsSmallDigit, boolean IsDivZero ) throws Throwable {
    double result = 0;
    IsSmallDigit = false;    
    if ( al.size() == 1 ) {
      if ( al.get( 0 ).mvalue.contains( "." ) ) // 
        IsSmallDigit = true;
      return Double.parseDouble( al.get( 0 ).mvalue );
    } // if
    Token t;
    Identifier ide;
    Stack<DoubleObj> st = new Stack<DoubleObj>();
    
    for ( int i = 0; i < al.size() ; i++ ) { // cal postfix
      t = al.get( i );
      if ( t.mtype == G.NUM ) {
        if ( t.mvalue.contains( "." ) ) // 
          IsSmallDigit = true;
        DoubleObj d = new DoubleObj( Double.parseDouble( t.mvalue ) );
        st.add( d );
      } // if
      
      else if ( t.mtype == G.IDENT ) {
        ide = G.GetIDInTable( t.mvalue );
        if ( ide.mcheck.equals( "DOUBLE" ) ) // 
          IsSmallDigit = true;
        DoubleObj de = new DoubleObj( ide.mnumvalue );
        st.add( de );
      } // else if
      
      else if ( t.mtype == G.SIGN || t.mtype == G.STAR || t.mtype == G.DIV ) {
        DoubleObj op2 = null;
        DoubleObj op1 = null;
        op2 = st.pop();
        op1 = st.pop();
        double e  = 0;
        DoubleObj res = null;
        if ( t.mvalue.equals( "+" ) ) { // 加減好像不該合再一起的
          e = op1.val + op2.val;
          res = new DoubleObj( e );
          st.push( res );
        } // if
        
        else if ( t.mvalue.equals( "-" ) ) {
          e = op1.val - op2.val;
          res = new DoubleObj( e );
          st.push( res );
        } // else if
        
        else if ( t.mtype == G.STAR ) { // *號
          e = op1.val * op2.val;
          res = new DoubleObj( e );
          st.push( res );
        } // else if
        
        else if ( t.mtype == G.DIV ) {
          if ( op2.val == 0 ) {
            IsDivZero = true; //除於0錯誤
            return 0;
          } // if
          
          e = op1.val / op2.val;
          res = new DoubleObj( e );
          st.push( res );
        } // else if
      } // else if
    } // for 
    
    result = st.pop().val; // 最後一個pop掉的值就是ans
    return result;  
  } // CalPostfix()
  
  public void SetTable( ArrayList<Token> table ) {
    mExpressionTable = table;    
  }  // SetTable()
  
  public int Priority(String op) {
    if ( op.equals( "+" ) || op.equals( "-" ) )
      return 1;
    else if ( op.equals( "*" ) || op.equals("/") )
      return 2;
    return 0;
  } // Priority()
  
  public void ClearIt() {
    mleft.clear();
    middle = "";
    mright.clear();
    mExpressionTable.clear();
    mHas_middle = false;
    mleftPostfix.clear();
    mrightPostfix.clear();
  } // ClearIt()
} // class Evalutor







class Main {

  public static void main( String[] args ) throws Throwable {
    G.Init();
    SCANNER sc = new SCANNER();
    PARSER ps = new PARSER(sc);
    Evalutor eu = new Evalutor();
    G.s_utestnum = G.sin.ReadInt(); // 留著debug用
    G.sin.ReadChar(); // 讀掉換行
    G.CYPrint( "Program starts...\n" );
    while ( ! G.sin.AtEOF() && G.s_quit == 0 ) {
      ps.ParserIt();  
      if ( ps.GetExecuteState() == true ) { // 這代表parser到可以解構了，也代表著要清除list的14
        eu.SetTable( ps.GetTable() );
        eu.Evalute();
        ps.ClearIt();
        eu.ClearIt();
      } // if
    } // while
    
    G.CYPrint( "> Program exits..." );
    return; 
  } // main()

