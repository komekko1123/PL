  public boolean GoFunction_Definition_Or_Declarators() throws Throwable { // 
    if ( mTokenList.get( mTCt ).mtype == G.LSP ) { // 小左括號就是GoFWithID
      if ( GoFunction_Definition_Without_ID() == true )
        return true;
