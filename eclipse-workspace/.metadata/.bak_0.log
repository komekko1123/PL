      return true;
    } // if
    
    else if ( mTokenList.get( mTCt ).mtype == G.CONSTANT ) {
      FetchToken();
      return true;
    } // else if 
    
    else if ( mTokenList.get( mTCt ).mtype == G.LSP ) {
