         mTokenList.get( mTCt ).mtype == G.MM   ||  mTokenList.get( mTCt ).mtype == G.CONSTANT  || 
         mTokenList.get( mTCt ).mtype == G.LSP || IsSign() )      
      return true;
    else 
      return false;
  } // IsStatement() 
  
  
